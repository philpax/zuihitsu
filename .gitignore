/target

# Environmental config — endpoints, credentials, DB paths. Per-instance, never committed.
/config*.toml

# Per-instance databases (the default config puts them here).
/data/

# Stage 0 spike (throwaway) — venv, caches, and run artifacts.
/spike/.venv/
__pycache__/
*.pyc
/spike/runs/
# fastembed (CPU embedding model) cache — model weights downloaded on first test run.
/.fastembed_cache/

# Eval harness: full packages (and their resumable .jsonl sidecars) are heavy local artifacts,
# kept under eval/<name>.json; only the small metrics history is tracked. Ignore everything else in
# eval/ — packages, sidecars, stray run logs, backups — so no artifact extension can leak into git
# just because we forgot to list it.
/eval/*
!/eval/history.jsonl
# The retired v1 trend archive, kept tracked (the v2 writer starts a fresh history.jsonl).
!/eval/history-v1.jsonl

# Generated wasm-bindgen output for the console bridge (regenerated from the build).
/crates/console-wasm/pkg/

# Generated console artifacts — the ts-rs TypeScript bindings, the settings metadata, and the
# wasm materializer bundle. All are produced by `cargo build -p zuihitsu` (Rust source is the truth)
# and built fresh by CI, so they are never committed.
/console/packages/wire/types/
/console/packages/wire/wasm/
