/target

# Environmental config — endpoints, credentials, DB paths. Per-instance, never committed.
/config.toml
# Alternate per-instance configs (e.g. a second model for eval comparison).
/config-*.toml

# Per-instance databases (the default config puts them here).
/data/

# Stage 0 spike (throwaway) — venv, caches, and run artifacts.
/spike/.venv/
__pycache__/
*.pyc
/spike/runs/
# wasm spike: wasm-bindgen-generated JS/wasm glue, regenerated from the build.
/console/spike/pkg/

# Eval harness: full packages are heavy local artifacts; the metrics history is tracked.
/eval/*.json
/eval/*.bak
/eval/runs/
